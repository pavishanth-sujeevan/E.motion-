    "from sklearn.metrics import confusion_matrix, classification_report\n",
    "import seaborn as sns\n",
    "\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# Label names\n",
    "emotion_labels = ['Neutral', 'Happy', 'Sad', 'Angry', 'Fear']\n",
    "\n",
    "# Use combined datasets from Phase B\n",
    "train_dataset_full = train_dataset_b\n",
    "val_dataset_full = val_dataset_b\n",
    "\n",
    "# Predict on train and validation sets\n",
    "train_output = trainer_b.predict(train_dataset_full)\n",
    "val_output = trainer_b.predict(val_dataset_full)\n",
    "\n",
    "def extract_preds(pred_output):\n",
    "    preds_raw = pred_output.predictions[0] if isinstance(pred_output.predictions, tuple) else pred_output.predictions\n",
    "    y_pred = preds_raw.argmax(axis=-1)\n",
    "    y_true = pred_output.label_ids\n",
    "    return y_true, y_pred\n",
    "\n",
    "train_y_true, train_y_pred = extract_preds(train_output)\n",
    "val_y_true, val_y_pred = extract_preds(val_output)\n",
    "\n",
    "# Metrics\n",
    "train_acc = (train_y_true == train_y_pred).mean()\n",
    "val_acc = (val_y_true == val_y_pred).mean()\n",
    "train_loss = train_output.metrics.get(\"test_loss\", float(\"nan\"))\n",
    "val_loss = val_output.metrics.get(\"test_loss\", float(\"nan\"))\n",
    "\n",
    "print(\"=== Summary Metrics ===\")\n",
    "print(f\"Train Accuracy     : {train_acc:.4f}\")\n",
    "print(f\"Train Loss         : {train_loss:.4f}\")\n",
    "print(f\"Validation Accuracy: {val_acc:.4f}\")\n",
    "print(f\"Validation Loss    : {val_loss:.4f}\")\n",
    "\n",
    "print(\"\\n=== Train Classification Report ===\")\n",
    "print(classification_report(train_y_true, train_y_pred, target_names=emotion_labels, digits=4))\n",
    "\n",
    "print(\"\\n=== Validation Classification Report ===\")\n",
    "print(classification_report(val_y_true, val_y_pred, target_names=emotion_labels, digits=4))\n",
    "\n",
    "# Confusion matrices\n",
    "train_cm = confusion_matrix(train_y_true, train_y_pred)\n",
